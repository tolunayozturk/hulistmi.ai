{
  "name": "@hulistmi/hulistmi",
  "version": "1.0.1",
  "description": "Making HarmonyOS docs AI-readable",
  "license": "MIT",
  "author": "hulistmi.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/hulistmi/hulistmi.ai"
  },
  "keywords": [
    "harmonyos",
    "huawei",
    "arkts",
    "arkui",
    "documentation",
    "mcp",
    "cli",
    "markdown",
    "ai"
  ],
  "preferGlobal": true,
  "homepage": "https://hulistmi.ai",
  "bugs": {
    "url": "https://github.com/hulistmi/hulistmi.ai/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20.18.1"
  },
  "files": [
    "bin",
    "src",
    "public",
    "wrangler.jsonc",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "hulistmi": "bin/hulistmi.mjs"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cli": "node ./bin/hulistmi.mjs",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test": "vitest",
    "test:run": "vitest run",
    "format": "biome check --write --linter-enabled=false .",
    "lint": "biome check --formatter-enabled=false .",
    "check": "biome check --write .",
    "check:ci": "biome check ."
  },
  "dependencies": {
    "@hono/mcp": "^0.1.2",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "cheerio": "^1.2.0",
    "hono": "^4.9.4",
    "tsx": "^4.22.4",
    "zod": "^3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@cloudflare/vitest-pool-workers": "^0.12.18",
    "@vitest/ui": "^3.2.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.32.0"
  }
}
