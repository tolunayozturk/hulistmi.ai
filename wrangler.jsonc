{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hulistmi-ai",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-10",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./public",
    "run_worker_first": ["/", "/.well-known/agent-skills/*"]
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "NODE_ENV": "production"
  }
}
